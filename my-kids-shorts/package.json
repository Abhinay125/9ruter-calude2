{
  "name": "my-kids-shorts",
  "version": "1.0.0",
  "description": "Kids educational shorts with React + Remotion",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render src/compositions/MainComposition.tsx MainComposition out/video.mp4",
    "build:all": "remotion render src/compositions/MainComposition.tsx MainComposition out/video.mp4 --concurrency=4",
    "preview": "remotion preview src/compositions/MainComposition.tsx MainComposition"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/tailwind": "^4.0.0",
    "typescript": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}